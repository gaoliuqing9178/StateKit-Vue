{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@statekit-vue/shared": ["packages/shared/src/index.ts"],
      "@statekit-vue/shared/*": ["packages/shared/src/*"],
      "@statekit-vue/vue": ["packages/vue/src/index.ts"],
      "@statekit-vue/vue/*": ["packages/vue/src/*"]
    }
  }
}
